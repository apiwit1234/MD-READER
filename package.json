{
  "name": "md-reader",
  "version": "1.0.5",
  "private": true,
  "description": "Personal markdown reader desktop app with multi-folder navigation, interactive mermaid, terminal, and resizable panels.",
  "author": "apiwit.wic",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:next": "next dev -p 3000",
    "dev:electron": "wait-on tcp:3000 && cross-env ELECTRON_DEV_URL=http://localhost:3000 electron .",
    "dev": "concurrently -k -n NEXT,ELECTRON -c blue,green \"npm:dev:next\" \"npm:dev:electron\"",
    "build:next": "next build",
    "build": "next build",
    "electron:start": "electron .",
    "dist": "npm run build:next && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "dist:dir": "npm run build:next && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist:portable": "npm run build:next && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "npm version patch"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@testing-library/jest-dom": "6.4.6",
    "@testing-library/react": "16.0.0",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/svg-pan-zoom": "3.4.0",
    "@vitejs/plugin-react": "4.3.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "autoprefixer": "10.4.19",
    "codemirror": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "happy-dom": "14.12.3",
    "highlight.js": "11.10.0",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.15.0",
    "next": "14.2.5",
    "postcss": "8.4.39",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "9.0.1",
    "react-resizable-panels": "^2.1.7",
    "rehype-highlight": "7.0.0",
    "remark-gfm": "4.0.0",
    "svg-pan-zoom": "3.6.1",
    "tailwindcss": "3.4.6",
    "typescript": "5.5.3",
    "vitest": "2.0.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "io.local.mdreader",
    "publish": {
      "provider": "github",
      "owner": "apiwit1234",
      "repo": "MD-READER"
    },
    "productName": "PAX Reader",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json",
      "!**/*.{md,d.ts,map}",
      "!**/{test,__tests__,tests,powered-test,example,examples}",
      "node_modules/node-pty/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "PAX-Reader-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "PAX-Reader-${version}-${arch}-portable.${ext}"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Viewer"
      },
      {
        "ext": "mmd",
        "name": "Mermaid diagram",
        "description": "Mermaid diagram source",
        "role": "Viewer"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "include": "electron/installer.nsh"
    },
    "asar": true
  }
}
